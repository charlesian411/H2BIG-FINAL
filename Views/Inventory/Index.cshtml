@model System.Data.DataTable
@{
    ViewData["Title"] = "Product Inventory";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Action Bar -->
<div class="bg-surface px-container-padding py-stack-md border-b border-outline-variant flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 shrink-0 shadow-sm z-0 relative mb-stack-md">
    <div>
        <h2 class="font-display-lg text-display-lg text-on-surface mb-1">Product Inventory</h2>
        <p class="font-body-sm text-body-sm text-on-surface-variant">Manage product catalog, pricing, and stock levels.</p>
    </div>
</div>

<div class="flex flex-row items-center gap-2 mb-4 shrink-0 justify-end">
    <button onclick="openAddModal()" class="h-10 bg-primary hover:bg-primary-container text-on-primary font-label-bold text-label-bold px-6 rounded flex items-center justify-center gap-2 transition-all duration-100 ease-in-out shadow-sm border border-transparent active:scale-95 whitespace-nowrap">
        <span class="material-symbols-outlined" data-icon="add_box">add_box</span>
        Add Product
    </button>
</div>

<!-- Summary Cards (Square Boxes for Default Qty) -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter mb-stack-md shrink-0">
    @foreach (System.Data.DataRow row in Model.Rows)
    {
        var defaultQty = Convert.ToInt32(row["default_qty"]);
        var stock = Convert.ToInt32(row["stock"]);
        var percentage = defaultQty > 0 ? (stock * 100 / defaultQty) : 0;
        
        <div class="win-panel p-stack-md rounded-xl shadow-sm border border-outline-variant flex flex-col gap-unit">
            <div class="flex items-center justify-between">
                <span class="text-[10px] font-bold text-outline uppercase tracking-wider">@row["name"]</span>
                <span class="material-symbols-outlined text-primary text-[20px]">inventory_2</span>
            </div>
            <div class="flex items-end justify-between">
                <div class="text-[28px] font-black text-on-surface">@defaultQty</div>
                <div class="text-[11px] font-bold @(percentage < 20 ? "text-error" : "text-primary")">
                    @stock in stock
                </div>
            </div>
            <div class="h-1 w-full bg-surface-container-high rounded-full mt-1 overflow-hidden">
                <div class="h-full @(percentage > 70 ? "bg-[#137333]" : percentage > 30 ? "bg-[#B06000]" : "bg-[#B3261E]")" style="width: @percentage%"></div>
            </div>
        </div>
    }
</div>

<div class="flex-1 bg-surface-container-lowest border border-outline-variant rounded shadow-sm flex flex-col overflow-hidden">
    <div class="overflow-x-auto flex-1">
        <table class="w-full text-left border-collapse">
            <thead class="bg-surface-container-low border-b border-outline-variant sticky top-0 z-10">
                <tr>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 w-12 text-center">ID</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50">Product Name</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 text-center">Price</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 text-center">Default Qty</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 text-center">Current Stock</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 text-center">Status</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline w-24 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="font-code-data text-code-data text-on-surface">
                @foreach (System.Data.DataRow row in Model.Rows)
                {
                    var stock = Convert.ToInt32(row["stock"]);
                    var defaultQty = Convert.ToInt32(row["default_qty"]);
                    var price = Convert.ToDecimal(row["price"]);
                    var statusColor = stock > (defaultQty * 0.7) ? "bg-[#E8F5E9] text-[#2E7D32]" : 
                                      stock > (defaultQty * 0.3) ? "bg-[#FFF8E1] text-[#F57F17]" : 
                                      "bg-[#FCE8E6] text-[#C5221F]";
                    var statusText = stock > (defaultQty * 0.7) ? "IN STOCK" : 
                                     stock > (defaultQty * 0.3) ? "LOW STOCK" : 
                                     "CRITICAL";

                    <tr class="border-b border-outline-variant/30 hover:bg-[#F0F7FF] transition-colors group">
                        <td class="py-2 px-3 border-r border-outline-variant/30 text-center text-outline">@row["id"]</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 font-semibold text-primary">@row["name"]</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 text-center text-on-surface-variant">₱@price.ToString("0.00")</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 font-bold text-center text-outline">@defaultQty</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 font-bold text-center">@stock</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 text-center">
                            <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-bold @statusColor">@statusText</span>
                        </td>
                        <td class="py-2 px-3 text-right text-center">
                            <div class="flex gap-1 transition-opacity justify-center">
                                <button onclick="openEditModal(@row["id"], '@row["name"]', @price, @stock, @defaultQty)" class="p-1 text-primary hover:bg-primary-container hover:text-on-primary-container rounded" title="Edit">
                                    <span class="material-symbols-outlined text-[16px]">edit</span>
                                </button>
                                <button onclick="openDeleteModal(@row["id"], '@row["name"]')" class="p-1 text-error hover:bg-error-container hover:text-on-error-container rounded" title="Delete">
                                    <span class="material-symbols-outlined text-[16px]">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Modal -->
<div id="addModal" class="hidden fixed inset-0 z-[100] overflow-auto bg-black/60 flex items-center justify-center backdrop-blur-sm p-4">
    <div class="bg-surface p-container-padding rounded-xl shadow-2xl w-full max-w-md border border-outline-variant animate-in fade-in zoom-in duration-200">
        <div class="flex justify-between items-center mb-6">
            <h3 class="font-headline-md text-primary font-bold">Add New Product</h3>
            <button onclick="closeAddModal()" class="text-outline hover:text-error transition-colors"><span class="material-symbols-outlined">close</span></button>
        </div>
        <form asp-action="Create" method="post" class="space-y-4">
            <div class="space-y-1">
                <label class="block font-label-bold text-on-surface-variant">Product Name</label>
                <input type="text" name="Name" required class="w-full border border-outline-variant rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary transition-all" />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label class="block font-label-bold text-on-surface-variant">Price (₱)</label>
                    <input type="number" step="0.01" name="Price" required class="w-full border border-outline-variant rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary transition-all" />
                </div>
                <div class="space-y-1">
                    <label class="block font-label-bold text-on-surface-variant">Default Qty</label>
                    <input type="number" name="DefaultQty" required class="w-full border border-outline-variant rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary transition-all" value="100" />
                </div>
            </div>
            <div class="space-y-1">
                <label class="block font-label-bold text-on-surface-variant">Initial Stock</label>
                <input type="number" name="Stock" required class="w-full border border-outline-variant rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary transition-all" value="0" />
            </div>
            <div class="pt-6 flex gap-3">
                <button type="button" onclick="closeAddModal()" class="flex-1 px-4 py-2.5 border border-outline-variant rounded-lg font-label-bold hover:bg-surface-container transition-colors">Cancel</button>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary text-on-primary rounded-lg font-label-bold hover:bg-[#003d7a] transition-all shadow-md">Add Product</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Modal -->
<div id="editModal" class="hidden fixed inset-0 z-[100] overflow-auto bg-black/60 flex items-center justify-center backdrop-blur-sm p-4">
    <div class="bg-surface p-container-padding rounded-xl shadow-2xl w-full max-w-md border border-outline-variant animate-in fade-in zoom-in duration-200">
        <div class="flex justify-between items-center mb-6">
            <h3 class="font-headline-md text-primary font-bold">Edit Product</h3>
            <button onclick="closeEditModal()" class="text-outline hover:text-error transition-colors"><span class="material-symbols-outlined">close</span></button>
        </div>
        <form asp-action="Edit" method="post" class="space-y-4">
            <input type="hidden" name="Id" id="editId" />
            <div class="space-y-1">
                <label class="block font-label-bold text-on-surface-variant">Product Name</label>
                <input type="text" name="Name" id="editName" required class="w-full border border-outline-variant rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary transition-all" />
            </div>
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-1">
                    <label class="block font-label-bold text-on-surface-variant">Price (₱)</label>
                    <input type="number" step="0.01" name="Price" id="editPrice" required class="w-full border border-outline-variant rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary transition-all" />
                </div>
                <div class="space-y-1">
                    <label class="block font-label-bold text-on-surface-variant">Default Qty</label>
                    <input type="number" name="DefaultQty" id="editDefaultQty" required class="w-full border border-outline-variant rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary transition-all" />
                </div>
            </div>
            <div class="space-y-1">
                <label class="block font-label-bold text-on-surface-variant">Current Stock</label>
                <input type="number" name="Stock" id="editStock" required class="w-full border border-outline-variant rounded-lg px-4 py-2.5 outline-none focus:ring-2 focus:ring-primary transition-all" />
            </div>
            <div class="pt-6 flex gap-3">
                <button type="button" onclick="closeEditModal()" class="flex-1 px-4 py-2.5 border border-outline-variant rounded-lg font-label-bold hover:bg-surface-container transition-colors">Cancel</button>
                <button type="submit" class="flex-1 px-4 py-2.5 bg-primary text-on-primary rounded-lg font-label-bold hover:bg-[#003d7a] transition-all shadow-md">Update Product</button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Modal -->
<div id="deleteModal" class="hidden fixed inset-0 z-[100] overflow-auto bg-black/60 flex items-center justify-center backdrop-blur-sm p-4">
    <div class="bg-surface p-container-padding rounded-xl shadow-2xl w-full max-w-sm border border-outline-variant animate-in fade-in zoom-in duration-200 text-center">
        <div class="w-16 h-16 bg-error-container text-error rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="material-symbols-outlined text-4xl">warning</span>
        </div>
        <h3 class="font-headline-md text-on-surface font-bold mb-2">Delete Product?</h3>
        <p class="text-on-surface-variant font-body-sm mb-6 px-4">Are you sure you want to delete <span id="deleteName" class="font-bold text-on-surface"></span>? This action cannot be undone.</p>
        
        <form asp-action="Delete" method="post" class="flex gap-3">
            <input type="hidden" name="id" id="deleteId" />
            <button type="button" onclick="closeDeleteModal()" class="flex-1 px-4 py-2.5 border border-outline-variant rounded-lg font-label-bold hover:bg-surface-container transition-colors">Cancel</button>
            <button type="submit" class="flex-1 px-4 py-2.5 bg-error text-on-error rounded-lg font-label-bold hover:bg-[#93000a] transition-all shadow-md">Delete</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() { document.getElementById('addModal').classList.remove('hidden'); }
        function closeAddModal() { document.getElementById('addModal').classList.add('hidden'); }
        function openEditModal(id, name, price, stock, defaultQty) {
            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editPrice').value = price;
            document.getElementById('editStock').value = stock;
            document.getElementById('editDefaultQty').value = defaultQty;
            document.getElementById('editModal').classList.remove('hidden');
        }
        function closeEditModal() { document.getElementById('editModal').classList.add('hidden'); }

        function openDeleteModal(id, name) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteName').innerText = name;
            document.getElementById('deleteModal').classList.remove('hidden');
        }
        function closeDeleteModal() { document.getElementById('deleteModal').classList.add('hidden'); }

        window.onkeydown = function(event) {
            if (event.key === "Escape") {
                closeAddModal();
                closeEditModal();
                closeDeleteModal();
            }
        }
    </script>
}
