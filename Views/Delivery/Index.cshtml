@model System.Data.DataTable
@{
    ViewData["Title"] = "Deliveries";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var userRole = Context.Session.GetString("UserRole");
}

<!-- Page Header -->
<div class="flex items-end justify-between mb-stack-md">
    <div>
        <h1 class="font-headline-md text-headline-md font-bold text-on-surface">DELIVERIES</h1>
        <p class="text-on-surface-variant font-body-sm text-body-sm mt-unit">Track and update ongoing delivery statuses.</p>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-stack-md">
    @foreach (System.Data.DataRow row in Model.Rows)
    {
        var status = row["status"].ToString();
        var statusColor = status == "Delivered" ? "bg-[#E8F5E9] text-[#2E7D32]" : 
                          status == "Cancelled" ? "bg-[#FCE8E6] text-[#C5221F]" : 
                          "bg-[#FFF8E1] text-[#F57F17]";

        <div class="bg-surface-container-lowest border border-outline-variant rounded p-stack-md flex flex-col gap-unit shadow-sm relative">
            <div class="flex justify-between items-start mb-2">
                <span class="font-label-bold text-label-bold text-outline uppercase">Delivery #@row["id"]</span>
                <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold @statusColor">@status</span>
            </div>
            
            <div class="mb-4">
                <h3 class="font-headline-md text-headline-md text-primary font-bold">@row["CustomerName"]</h3>
                <p class="font-body-sm text-body-sm text-on-surface-variant flex items-center gap-1 mt-1">
                    <span class="material-symbols-outlined text-[16px]">location_on</span>
                    @row["address"]
                </p>
            </div>

            <div class="flex justify-between items-center bg-surface-container-low p-2 rounded border border-outline-variant/50 font-body-sm text-body-sm text-on-surface mb-4">
                <span>Sale #@row["sale_id"]</span>
                <span class="font-bold text-primary">₱@row["total_amount"]</span>
            </div>

            @if (userRole == "Admin" || userRole == "Staff")
            {
                <div class="text-body-sm text-outline flex items-center gap-1 mb-4">
                    <span class="material-symbols-outlined text-[16px]">person</span>
                    Rider: <span class="font-bold text-on-surface">@row["RiderName"]</span>
                </div>
            }

            <div class="mt-auto pt-4 border-t border-outline-variant flex gap-2">
                @if (status == "Pending")
                {
                    <form asp-action="MarkAsDelivered" method="post" class="flex-1">
                        <input type="hidden" name="deliveryId" value="@row["id"]" />
                        <button type="submit" class="w-full bg-[#10b981] hover:bg-[#059669] text-white font-label-bold py-2 rounded flex items-center justify-center gap-1 transition-colors">
                            <span class="material-symbols-outlined text-[18px]">check_circle</span>
                            Mark Delivered
                        </button>
                    </form>
                    
                    @if (userRole == "Admin" || userRole == "Staff")
                    {
                        <form asp-action="CancelDelivery" method="post">
                            <input type="hidden" name="deliveryId" value="@row["id"]" />
                            <button type="submit" class="bg-surface border border-error text-error hover:bg-error-container font-label-bold py-2 px-3 rounded flex items-center justify-center transition-colors">
                                <span class="material-symbols-outlined text-[18px]">cancel</span>
                            </button>
                        </form>
                    }
                }
            </div>
        </div>
    }

    @if (Model.Rows.Count == 0)
    {
        <div class="col-span-full bg-surface-container border border-outline-variant rounded p-stack-lg text-center text-on-surface-variant">
            <span class="material-symbols-outlined text-4xl mb-2 text-outline">local_shipping</span>
            <p>No active deliveries found.</p>
        </div>
    }
</div>
