@{
    ViewData["Title"] = "Admin Reports";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var debtAlerts = ViewBag.DebtAlerts as System.Data.DataTable;
}

<!-- Page Header -->
<div class="flex items-end justify-between mb-stack-md">
    <div>
        <h1 class="font-headline-md text-headline-md font-bold text-on-surface">BUSINESS REPORTS</h1>
        <p class="text-on-surface-variant font-body-sm text-body-sm mt-unit">Executive summary and system metrics.</p>
    </div>
</div>

<!-- KPI Cards Grid -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-gutter mt-stack-lg">
    <!-- Today -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded p-stack-md flex flex-col gap-unit hover:border-outline transition-colors relative overflow-hidden group">
        <div class="flex justify-between items-start">
            <span class="font-label-bold text-label-bold text-on-surface-variant">Sales Today</span>
            <span class="material-symbols-outlined text-primary text-[20px]">payments</span>
        </div>
        <div class="font-display-lg text-display-lg text-on-surface mt-stack-sm">₱@ViewBag.TotalSalesToday.ToString("N2")</div>
        <div class="absolute bottom-0 left-0 h-1 w-full bg-primary scale-x-0 group-hover:scale-x-100 origin-left transition-transform duration-300"></div>
    </div>

    <!-- Weekly -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded p-stack-md flex flex-col gap-unit hover:border-outline transition-colors relative overflow-hidden group">
        <div class="flex justify-between items-start">
            <span class="font-label-bold text-label-bold text-on-surface-variant">Sales (7 Days)</span>
            <span class="material-symbols-outlined text-outline text-[20px]">calendar_view_week</span>
        </div>
        <div class="font-display-lg text-display-lg text-on-surface mt-stack-sm">₱@ViewBag.TotalSalesWeekly.ToString("N2")</div>
    </div>

    <!-- Most Sold -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded p-stack-md flex flex-col gap-unit hover:border-outline transition-colors relative overflow-hidden group">
        <div class="flex justify-between items-start">
            <span class="font-label-bold text-label-bold text-on-surface-variant">Best Seller</span>
            <span class="material-symbols-outlined text-primary text-[20px]">star</span>
        </div>
        <div class="font-display-lg text-display-lg text-on-surface mt-stack-sm truncate" title="@ViewBag.MostSoldProduct">@ViewBag.MostSoldProduct</div>
    </div>

    <!-- Outstanding Bottle Debt (Alert State) -->
    <div class="bg-surface-container-lowest border border-error rounded p-stack-md flex flex-col gap-unit relative overflow-hidden group">
        <div class="absolute inset-0 bg-error-container opacity-20 pointer-events-none"></div>
        <div class="flex justify-between items-start relative z-10">
            <span class="font-label-bold text-label-bold text-on-error-container flex items-center gap-unit">
                <span class="material-symbols-fill text-[16px]">warning</span>
                Total Bottle Debt
            </span>
            <span class="material-symbols-outlined text-error text-[20px]">water_bottle</span>
        </div>
        <div class="font-display-lg text-display-lg text-on-error-container mt-stack-sm relative z-10">@ViewBag.TotalBottleDebt</div>
        <div class="absolute bottom-0 left-0 h-1 w-full bg-error"></div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter mt-stack-lg">
    <!-- Debt Alerts List -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded flex flex-col h-[400px] shadow-sm">
        <div class="p-stack-sm px-stack-md border-b border-outline-variant flex justify-between items-center bg-surface-container-low">
            <h2 class="font-label-bold text-label-bold text-on-surface flex items-center gap-unit">
                <span class="material-symbols-outlined text-[18px] text-error">assignment_late</span>
                Top Debtors
            </h2>
            <span class="text-[11px] font-bold text-on-surface-variant">Requires Attention</span>
        </div>
        <div class="flex-1 overflow-y-auto">
            <table class="w-full text-left border-collapse font-code-data text-code-data">
                <thead class="sticky top-0 bg-surface-container-lowest border-b border-outline-variant shadow-[0_1px_0_0_#c2c6d4]">
                    <tr>
                        <th class="py-unit px-stack-sm font-label-bold text-on-surface-variant">Customer</th>
                        <th class="py-unit px-stack-sm font-label-bold text-on-surface-variant text-right">Debt Qty</th>
                        <th class="py-unit px-stack-sm font-label-bold text-on-surface-variant text-right">Severity</th>
                    </tr>
                </thead>
                <tbody>
                    @if (debtAlerts != null)
                    {
                        foreach (System.Data.DataRow row in debtAlerts.Rows)
                        {
                            var severity = row["Status"].ToString();
                            var severityColor = severity == "Critical" ? "text-error font-bold" : 
                                                severity == "Warning" ? "text-[#F57F17] font-bold" : 
                                                "text-primary font-bold";

                            <tr class="border-b border-outline-variant hover:bg-surface-container-low transition-colors group cursor-pointer">
                                <td class="py-stack-sm px-stack-sm text-on-surface truncate max-w-[120px]">@row["name"]</td>
                                <td class="py-stack-sm px-stack-sm text-on-surface text-right">@row["bottle_debt"]</td>
                                <td class="py-stack-sm px-stack-sm text-right">
                                    <span class="inline-flex items-center px-2 py-0.5 rounded text-[10px] font-bold @(severity == "Critical" ? "bg-error-container text-on-error-container" : severity == "Warning" ? "bg-[#FFF8E1] text-[#F57F17]" : "bg-primary-container text-on-primary-container")">
                                        @severity
                                    </span>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Logistics Analytics -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded flex flex-col h-[400px] shadow-sm">
        <div class="p-stack-sm px-stack-md border-b border-outline-variant flex justify-between items-center bg-surface-container-low">
            <h2 class="font-label-bold text-label-bold text-on-surface flex items-center gap-unit">
                <span class="material-symbols-outlined text-[18px] text-primary">local_shipping</span>
                Logistics Overview
            </h2>
        </div>
        <div class="flex-1 p-stack-md flex flex-col gap-4">
            <div class="flex items-center justify-between p-4 bg-surface rounded border border-outline-variant">
                <div>
                    <p class="text-on-surface-variant font-label-bold text-label-bold uppercase">Pending Orders</p>
                    <h3 class="font-display-lg text-display-lg text-primary">@ViewBag.PendingDeliveries</h3>
                </div>
                <span class="material-symbols-outlined text-outline text-4xl">hourglass_empty</span>
            </div>
            <div class="flex items-center justify-between p-4 bg-surface rounded border border-outline-variant">
                <div>
                    <p class="text-on-surface-variant font-label-bold text-label-bold uppercase">Completed Today</p>
                    <h3 class="font-display-lg text-display-lg text-[#137333]">@ViewBag.CompletedDeliveries</h3>
                </div>
                <span class="material-symbols-outlined text-[#137333] text-4xl">task_alt</span>
            </div>
        </div>
    </div>
</div>
