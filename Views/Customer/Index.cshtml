@model IEnumerable<H2BIG.Models.Customer>
@{
    ViewData["Title"] = "Customer Management";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Header -->
<div class="flex items-end justify-between mb-stack-md">
    <div>
        <h1 class="font-headline-md text-headline-md font-bold text-on-surface uppercase">Customer Management</h1>
        <p class="text-on-surface-variant font-body-sm text-body-sm mt-unit">Manage client accounts, bottle deposits, and contact information.</p>
    </div>
</div>

<!-- Statistics Row -->
<div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-stack-md shrink-0">
    <div class="bg-surface-container-lowest border border-outline-variant p-4 rounded shadow-sm flex items-center justify-between">
        <div>
            <p class="font-label-bold text-label-bold text-on-surface-variant mb-1 uppercase tracking-wider">Total Active</p>
            <p class="font-headline-md text-headline-md text-on-surface">@ViewBag.TotalCustomers</p>
        </div>
        <div class="w-10 h-10 rounded-full bg-[#F0F7FF] flex items-center justify-center text-primary">
            <span class="material-symbols-outlined" data-icon="groups">groups</span>
        </div>
    </div>
    <div class="bg-surface-container-lowest border border-outline-variant p-4 rounded shadow-sm flex items-center justify-between">
        <div>
            <p class="font-label-bold text-label-bold text-on-surface-variant mb-1 uppercase tracking-wider">Total Bottle Debt</p>
            <p class="font-headline-md text-headline-md text-error">@ViewBag.TotalDebt</p>
        </div>
        <div class="w-10 h-10 rounded-full bg-error-container flex items-center justify-center text-on-error-container">
            <span class="material-symbols-outlined" data-icon="water_bottle">water_bottle</span>
        </div>
    </div>
    <div class="bg-surface-container-lowest border border-outline-variant p-4 rounded shadow-sm flex items-center justify-between">
        <div>
            <p class="font-label-bold text-label-bold text-on-surface-variant mb-1 uppercase tracking-wider">New This Month</p>
            <p class="font-headline-md text-headline-md text-on-surface">@ViewBag.NewCustomers</p>
        </div>
        <div class="w-10 h-10 rounded-full bg-[#F0F7FF] flex items-center justify-center text-primary">
            <span class="material-symbols-outlined" data-icon="trending_up">trending_up</span>
        </div>
    </div>
</div>

<!-- Data Grid Component -->
<div class="flex flex-row items-center gap-2 mb-4 shrink-0">
    <form asp-action="Index" method="get" class="relative flex-1 flex gap-2">
        <div class="relative flex-1">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline" data-icon="search">search</span>
            <input name="search" value="@ViewContext.HttpContext.Request.Query["search"]" class="w-full h-10 pl-10 pr-4 py-2 bg-surface-container-lowest border border-outline-variant rounded focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent font-body-base text-body-base" placeholder="Search customers by name..." type="text" />
        </div>
        <button type="submit" class="h-10 bg-surface border border-outline-variant text-on-surface px-4 rounded hover:bg-surface-container transition-colors">Search</button>
    </form>
    <button onclick="openAddModal()" class="h-10 bg-primary hover:bg-primary-container text-on-primary font-label-bold text-label-bold px-6 rounded flex items-center justify-center gap-2 transition-all duration-100 ease-in-out shadow-sm border border-transparent active:scale-95 whitespace-nowrap">
        <span class="material-symbols-outlined" data-icon="person_add">person_add</span>
        Add New Customer
    </button>
</div>

<div class="flex-1 bg-surface-container-lowest border border-outline-variant rounded shadow-sm flex flex-col overflow-hidden">
    <div class="overflow-x-auto flex-1">
        <table class="w-full text-left border-collapse">
            <thead class="bg-surface-container-low border-b border-outline-variant sticky top-0 z-10">
                <tr>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 w-12 text-center">ID</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 text-center">Customer Name</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 text-center">Contact Number</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 text-center">Primary Address</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 text-center">Bottle Debt</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 text-center">Joined</th>
                    <th class="py-2 px-3 font-label-bold text-label-bold text-outline w-24 text-center">Actions</th>
                </tr>
            </thead>
            <tbody class="font-code-data text-code-data text-on-surface">
                @foreach (var item in Model)
                {
                    <tr class="border-b border-outline-variant/30 hover:bg-[#F0F7FF] transition-colors group">
                        <td class="py-2 px-3 border-r border-outline-variant/30 text-center text-outline">@item.Id</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 font-semibold text-primary text-center">@item.Name</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 text-center">@item.Contact</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 truncate max-w-[200px] text-center" title="@item.Address">@item.Address</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 font-bold @(item.BottleDebt > 0 ? "text-error" : "text-primary") text-center">@item.BottleDebt</td>
                        <td class="py-2 px-3 border-r border-outline-variant/30 text-center">@item.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td class="py-2 px-3 text-right text-center">
                            <div class="flex gap-1 transition-opacity justify-center opacity-100">
                                <button onclick="openEditModal(@item.Id, '@item.Name', '@item.Contact', '@item.Address')" class="p-1 text-primary hover:bg-primary-container hover:text-on-primary-container rounded" title="Edit">
                                    <span class="material-symbols-outlined text-[16px]" data-icon="edit">edit</span>
                                </button>
                                <button onclick="openDeleteModal(@item.Id, '@item.Name')" class="p-1 text-error hover:bg-error-container hover:text-on-error-container rounded" title="Delete">
                                    <span class="material-symbols-outlined text-[16px]" data-icon="delete">delete</span>
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Add Customer Modal -->
<div id="addModal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center backdrop-blur-sm p-4">
    <div class="bg-surface p-container-padding rounded-xl shadow-2xl w-full max-w-md border border-outline-variant animate-in fade-in zoom-in duration-200">
        <div class="flex justify-between items-center mb-stack-md border-b border-outline-variant pb-stack-sm">
            <h3 class="font-headline-md text-headline-md text-primary font-bold">Add New Customer</h3>
            <button onclick="closeAddModal()" class="text-outline hover:text-error transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-action="Create" method="post" class="space-y-stack-md">
            <div>
                <label class="block font-label-bold text-label-bold text-on-surface-variant mb-1">Full Name</label>
                <input type="text" name="Name" required class="w-full border border-outline-variant rounded px-3 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none" />
            </div>
            <div>
                <label class="block font-label-bold text-label-bold text-on-surface-variant mb-1">Contact Number</label>
                <input type="text" name="Contact" required class="w-full border border-outline-variant rounded px-3 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none" />
            </div>
            <div>
                <label class="block font-label-bold text-label-bold text-on-surface-variant mb-1">Primary Address</label>
                <textarea name="Address" required class="w-full border border-outline-variant rounded px-3 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none h-24"></textarea>
            </div>
            <div class="pt-4 flex gap-2">
                <button type="button" onclick="closeAddModal()" class="flex-1 px-4 py-2 border border-outline-variant rounded font-label-bold hover:bg-surface-container transition-colors">Cancel</button>
                <button type="submit" class="flex-1 px-4 py-2 bg-primary text-on-primary rounded font-label-bold hover:bg-primary-container transition-colors">Save Customer</button>
            </div>
        </form>
    </div>
</div>

<!-- Edit Customer Modal -->
<div id="editModal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center backdrop-blur-sm p-4">
    <div class="bg-surface p-container-padding rounded-xl shadow-2xl w-full max-w-md border border-outline-variant animate-in fade-in zoom-in duration-200">
        <div class="flex justify-between items-center mb-stack-md border-b border-outline-variant pb-stack-sm">
            <h3 class="font-headline-md text-headline-md text-primary font-bold">Edit Customer</h3>
            <button onclick="closeEditModal()" class="text-outline hover:text-error transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form asp-action="Edit" method="post" class="space-y-stack-md">
            <input type="hidden" name="Id" id="editId" />
            <div>
                <label class="block font-label-bold text-label-bold text-on-surface-variant mb-1">Full Name</label>
                <input type="text" name="Name" id="editName" required class="w-full border border-outline-variant rounded px-3 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none" />
            </div>
            <div>
                <label class="block font-label-bold text-label-bold text-on-surface-variant mb-1">Contact Number</label>
                <input type="text" name="Contact" id="editContact" required class="w-full border border-outline-variant rounded px-3 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none" />
            </div>
            <div>
                <label class="block font-label-bold text-label-bold text-on-surface-variant mb-1">Primary Address</label>
                <textarea name="Address" id="editAddress" required class="w-full border border-outline-variant rounded px-3 py-2 focus:ring-2 focus:ring-primary focus:border-transparent outline-none h-24"></textarea>
            </div>
            <div class="pt-4 flex gap-2">
                <button type="button" onclick="closeEditModal()" class="flex-1 px-4 py-2 border border-outline-variant rounded font-label-bold hover:bg-surface-container transition-colors">Cancel</button>
                <button type="submit" class="flex-1 px-4 py-2 bg-primary text-on-primary rounded font-label-bold hover:bg-primary-container transition-colors">Update Changes</button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="hidden fixed inset-0 z-50 overflow-auto bg-black bg-opacity-50 flex items-center justify-center backdrop-blur-sm p-4">
    <div class="bg-surface p-container-padding rounded-xl shadow-2xl w-full max-w-sm border border-outline-variant animate-in fade-in zoom-in duration-200 text-center">
        <div class="w-16 h-16 bg-error-container text-error rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="material-symbols-outlined text-4xl">warning</span>
        </div>
        <h3 class="font-headline-md text-headline-md text-on-surface font-bold mb-2">Delete Customer?</h3>
        <p class="text-on-surface-variant font-body-sm mb-6">Are you sure you want to delete <span id="deleteName" class="font-bold text-on-surface"></span>? This action cannot be undone.</p>
        
        <form asp-action="Delete" method="post" class="flex gap-2">
            <input type="hidden" name="id" id="deleteId" />
            <button type="button" onclick="closeDeleteModal()" class="flex-1 px-4 py-2 border border-outline-variant rounded font-label-bold hover:bg-surface-container transition-colors">Cancel</button>
            <button type="submit" class="flex-1 px-4 py-2 bg-error text-on-error rounded font-label-bold hover:bg-[#93000a] transition-colors shadow-sm">Delete</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        function openAddModal() { document.getElementById('addModal').classList.remove('hidden'); }
        function closeAddModal() { document.getElementById('addModal').classList.add('hidden'); }
        
        function openEditModal(id, name, contact, address) {
            document.getElementById('editId').value = id;
            document.getElementById('editName').value = name;
            document.getElementById('editContact').value = contact;
            document.getElementById('editAddress').value = address;
            document.getElementById('editModal').classList.remove('hidden');
        }
        function closeEditModal() { document.getElementById('editModal').classList.add('hidden'); }

        function openDeleteModal(id, name) {
            document.getElementById('deleteId').value = id;
            document.getElementById('deleteName').innerText = name;
            document.getElementById('deleteModal').classList.remove('hidden');
        }
        function closeDeleteModal() { document.getElementById('deleteModal').classList.add('hidden'); }

        window.onkeydown = function(event) {
            if (event.key === "Escape") {
                closeAddModal();
                closeEditModal();
                closeDeleteModal();
            }
        }
    </script>
}
