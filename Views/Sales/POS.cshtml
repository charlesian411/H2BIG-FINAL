@{
    ViewData["Title"] = "POS / Sales";
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var products = ViewBag.Products as System.Data.DataTable;
    var customers = ViewBag.Customers as System.Data.DataTable;
    var riders = ViewBag.Riders as System.Data.DataTable;
}

<style>
    .win-border { border: 1px solid #727783; }
    .win-panel { background-color: #FFFFFF; border: 1px solid #c2c6d4; }
    .product-card:hover { border-color: #00488d; }
</style>

<!-- Page Header -->
<div class="flex-none mb-stack-md">
    <h1 class="font-headline-md text-headline-md font-bold text-on-surface uppercase">POS / SALES</h1>
    <p class="text-on-surface-variant font-body-sm text-body-sm mt-unit">Manage walk-in sales and delivery assignments.</p>
</div>

<div class="flex-1 flex gap-gutter p-container-padding overflow-hidden h-full">
    <!-- Left Side: Product Selection -->
    <section class="flex-1 flex flex-col gap-stack-md h-full">
        <!-- Customer Context Bar (Dashed/Minimal Border) -->
        <div class="win-panel p-stack-sm flex items-center justify-between shadow-sm relative z-[60] !border-none !bg-transparent !shadow-none">
            <div class="flex items-center w-full gap-stack-md">
                <div class="flex items-center gap-[2px] p-[2px] bg-surface-container-low border border-outline-variant rounded shrink-0">
                    <button type="button" onclick="setOrderType('Walk-In')" id="tabWalkIn" class="px-stack-sm py-1 bg-surface shadow-sm rounded font-label-bold text-label-bold text-primary border border-outline-variant transition-all">Walk-in</button>
                    <button type="button" onclick="setOrderType('Delivery')" id="tabDelivery" class="px-stack-sm py-1 text-on-surface-variant hover:bg-surface-variant rounded font-label-bold text-label-bold transition-all">Delivery</button>
                </div>
                <div id="customerSearchContainer" class="flex-1 flex win-border rounded bg-surface-container-lowest focus-within:ring-1 focus-within:ring-primary focus-within:border-primary relative hidden">
                    <div class="relative flex-1 flex items-center">
                        <span class="material-symbols-outlined absolute left-2 text-outline text-[18px]">person_search</span>
                        <input type="text" id="customerSearchInput" onkeyup="searchCustomers(this.value)" placeholder="Search Customer Name..." class="w-full pl-8 pr-unit py-1.5 text-body-base font-body-base border-none outline-none focus:ring-0 bg-transparent" />
                        <!-- Autocomplete Dropdown -->
                        <div id="customerResults" class="absolute top-full left-0 w-full bg-surface-container-lowest border border-outline-variant shadow-lg rounded-b z-50 hidden max-h-60 overflow-y-auto">
                            @if (customers != null)
                            {
                                foreach (System.Data.DataRow row in customers.Rows)
                                {
                                    <div class="p-3 hover:bg-surface-container-low cursor-pointer border-b border-outline-variant last:border-0 group customer-item" 
                                         onclick="selectCustomer(@row["id"], '@row["name"]', '@row["address"]')">
                                        <div class="font-label-bold text-on-surface group-hover:text-primary transition-colors customer-name">@row["name"]</div>
                                        <div class="text-[10px] text-outline truncate flex items-center gap-1">
                                            <span class="material-symbols-outlined text-[12px]">location_on</span> @row["address"]
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Grid Container -->
        <div class="flex-1 overflow-y-auto win-panel p-stack-md shadow-sm flex flex-col">
            <div class="flex items-center justify-between mb-stack-md border-b border-outline-variant pb-unit">
                <h2 class="font-headline-md text-headline-md text-on-surface uppercase tracking-tight">Products</h2>
                <div class="relative w-72">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline text-[18px]">search</span>
                    <input type="text" onkeyup="filterProducts(this.value)" placeholder="Search products..." class="w-full pl-10 pr-4 py-1.5 bg-surface-container-lowest border border-outline-variant rounded-full font-body-sm text-body-sm focus:ring-1 focus:ring-primary outline-none transition-all" />
                </div>
            </div>
            
            <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-stack-md" id="productGrid">
                @if (products != null)
                {
                    foreach (System.Data.DataRow row in products.Rows)
                    {
                        var productId = row["id"];
                        var name = row["name"].ToString();
                        var price = Convert.ToDecimal(row["price"]);
                        var stock = Convert.ToInt32(row["stock"]);
                        
                        <div class="product-card border border-outline-variant rounded bg-surface-container-lowest cursor-pointer group transition-all flex flex-col h-full active:scale-[0.98] @(stock <= 0 ? "opacity-50 pointer-events-none" : "")" 
                             data-name="@name.ToLower()"
                             onclick="addToCart(@productId, '@name', @price, @stock)">
                            <!-- Card Header -->
                            <div class="p-stack-sm border-b border-outline-variant bg-surface-container-low flex justify-between items-start rounded-t">
                                <span class="material-symbols-outlined text-primary text-[28px]">water_bottle</span>
                                <span class="@(stock > 50 ? "bg-[#E6F4EA] text-[#137333] border-[#CEEAD6]" : stock > 0 ? "bg-[#FFF8E1] text-[#F57F17] border-[#FFE082]" : "bg-[#FCE8E6] text-[#C5221F] border-[#F9D0C4]") px-2 py-[2px] rounded text-[10px] font-bold border whitespace-nowrap">Stock: @stock</span>
                            </div>
                            <!-- Card Body -->
                            <div class="p-stack-md flex-1 flex flex-col justify-between">
                                <div>
                                    <h3 class="font-label-bold text-label-bold text-on-surface line-clamp-2 min-h-[32px]">@name</h3>
                                    <p class="font-code-data text-code-data text-primary mt-unit">₱@price.ToString("0.00")</p>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </section>

    <!-- Right Side: Order Summary -->
    <aside class="w-96 flex flex-col h-full win-panel shadow-md overflow-hidden">
        <form asp-action="Process" method="post" id="posForm" class="flex flex-col h-full" onsubmit="handleProcessSale(event)">
            <input type="hidden" name="type" id="orderTypeInput" value="Walk-In" />
            <input type="hidden" name="customerId" id="customerIdInput" value="0" />
            <input type="hidden" name="riderId" id="riderIdInput" value="" />
            <input type="hidden" name="totalAmount" id="totalAmountInput" value="0" />
            <input type="hidden" name="cartJson" id="cartJsonInput" value="[]" />

            <!-- Summary Header -->
            <div class="p-stack-md border-b border-outline-variant bg-surface-container-low">
                <div class="flex items-center justify-between mb-2">
                    <h2 class="font-headline-md text-headline-md text-on-surface font-bold">Order Summary</h2>
                    <span class="font-label-bold text-label-bold bg-primary text-on-primary px-3 py-1 rounded shadow-sm">Ticket #@DateTime.Now.ToString("HHmm")</span>
                </div>
                <div class="flex flex-col gap-2 bg-surface-container-lowest p-3 rounded border border-outline-variant">
                    <div class="flex items-center text-on-surface font-label-bold text-label-bold gap-2">
                        <span class="material-symbols-outlined text-[18px] text-primary">account_circle</span>
                        <span id="displayCustomerName">Guest (Walk-in)</span>
                    </div>
                    <div id="customerDetails" class="hidden text-[11px] text-on-surface-variant font-code-data border-t border-outline-variant pt-1 mt-1">
                        <div class="flex items-center gap-1"><span class="material-symbols-outlined text-[14px]">location_on</span> <span id="displayCustomerAddress">No Address</span></div>
                    </div>
                </div>
            </div>

            <!-- Cart Items Container -->
            <div id="cartItems" class="flex-1 overflow-y-auto p-stack-sm bg-surface-container-lowest">
                <!-- Empty State -->
                <div class="h-full flex items-center justify-center text-outline opacity-40 flex-col gap-4">
                    <span class="material-symbols-outlined text-6xl">shopping_cart</span>
                    <p class="font-body-base">Empty Cart</p>
                </div>
            </div>

            <!-- Calculation Section -->
            <div class="p-stack-md border-t border-outline-variant bg-surface-container-low shadow-[0_-2px_4px_rgba(0,0,0,0.02)]">
                <div class="space-y-2 mb-4">
                    <div class="flex justify-between items-center text-on-surface-variant font-body-base">
                        <span>Subtotal</span>
                        <span class="font-code-data" id="displaySubtotal">₱0.00</span>
                    </div>
                    <div class="flex justify-between items-center text-on-surface-variant font-body-base">
                        <span>Tax (0%)</span>
                        <span class="font-code-data" id="displayTax">₱0.00</span>
                    </div>
                    <div class="pt-2 border-t border-outline flex justify-between items-center">
                        <span class="font-headline-md text-on-surface">Total</span>
                        <span class="font-display-lg text-primary" id="cartTotal">₱0.00</span>
                    </div>
                </div>
                
                <button type="submit" id="submitBtn" disabled class="w-full bg-primary disabled:bg-outline-variant hover:bg-[#003d7a] text-on-primary font-headline-md text-headline-md py-4 rounded shadow-md flex items-center justify-center gap-3 transition-all uppercase tracking-widest active:scale-[0.99]">
                    <span class="material-symbols-outlined">check_circle</span>
                    Process Sale
                </button>
            </div>
        </form>
    </aside>
</div>

<!-- Rider Selection Modal -->
<div id="riderModal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] hidden flex items-center justify-center p-4">
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-2xl w-full max-w-md overflow-hidden animate-in fade-in zoom-in-95 duration-200">
        <div class="p-stack-md border-b border-outline-variant bg-surface-container-low flex justify-between items-center">
            <h3 class="font-headline-md text-headline-md text-on-surface flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">local_shipping</span>
                Assign Delivery Rider
            </h3>
            <button onclick="closeRiderModal()" class="text-outline hover:text-on-surface transition-colors">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <div class="p-stack-md">
            <p class="text-on-surface-variant font-body-sm mb-4">Select an available rider to process this delivery order.</p>
            <div class="grid gap-2" id="riderList">
                @if (riders != null && riders.Rows.Count > 0)
                {
                    foreach (System.Data.DataRow row in riders.Rows)
                    {
                        var currentLoad = Convert.ToInt32(row["current_load"]);
                        var isFull = currentLoad >= 20;
                        var remaining = 20 - currentLoad;

                        <div onclick="@(isFull ? "" : $"selectRider({row["id"]}, this)")" 
                             class="p-4 border border-outline-variant rounded-lg @(isFull ? "bg-surface-container-high opacity-60 cursor-not-allowed" : "cursor-pointer hover:bg-surface-container-low transition-all") flex items-center justify-between group">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 rounded-full @(isFull ? "bg-outline" : "bg-primary-container") flex items-center justify-center @(isFull ? "text-on-surface-variant" : "text-primary")">
                                    <span class="material-symbols-outlined">person</span>
                                </div>
                                <div>
                                    <div class="font-label-bold text-on-surface">@row["fullname"]</div>
                                    <div class="text-[11px] @(isFull ? "text-error" : "text-[#137333]") font-bold uppercase tracking-wider">
                                        @(isFull ? "Unavailable (Full)" : "Available")
                                    </div>
                                </div>
                            </div>
                            <div class="flex flex-col items-end gap-1">
                                <div class="flex items-center gap-1 text-on-surface-variant">
                                    <span class="material-symbols-outlined text-[18px]">water_bottle</span>
                                    <span class="font-code-data text-code-data @(isFull ? "text-error font-bold" : "")">@currentLoad/20</span>
                                </div>
                                @if (!isFull)
                                {
                                    <span class="text-[9px] text-outline uppercase font-label-bold">@remaining left</span>
                                }
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-8 text-outline italic">No active riders available</div>
                }
            </div>
        </div>
        <div class="p-stack-md bg-surface-container-low border-t border-outline-variant flex justify-end gap-3">
            <button onclick="closeRiderModal()" class="px-6 py-2 border border-outline-variant rounded-full font-label-bold text-on-surface-variant hover:bg-surface-variant transition-colors">Cancel</button>
            <button onclick="confirmRiderSelection()" id="confirmRiderBtn" disabled class="px-6 py-2 bg-primary disabled:bg-outline-variant text-on-primary rounded-full font-label-bold shadow-sm transition-all">Confirm Assignment</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let cart = {};
        let currentOrderType = "Walk-In";

        function setOrderType(type) {
            currentOrderType = type;
            document.getElementById('orderTypeInput').value = type;
            
            const wBtn = document.getElementById('tabWalkIn');
            const dBtn = document.getElementById('tabDelivery');
            const searchContainer = document.getElementById('customerSearchContainer');
            const details = document.getElementById('customerDetails');
            
            if(type === 'Walk-In') {
                wBtn.className = "px-stack-sm py-1 bg-surface shadow-sm rounded font-label-bold text-label-bold text-primary border border-outline-variant transition-all";
                dBtn.className = "px-stack-sm py-1 text-on-surface-variant hover:bg-surface-variant rounded font-label-bold text-label-bold transition-all";
                searchContainer.classList.add('hidden');
                // Reset customer to Guest for Walk-In
                selectCustomer(0, "Walk-In Customer", "");
            } else {
                dBtn.className = "px-stack-sm py-1 bg-surface shadow-sm rounded font-label-bold text-label-bold text-primary border border-outline-variant transition-all";
                wBtn.className = "px-stack-sm py-1 text-on-surface-variant hover:bg-surface-variant rounded font-label-bold text-label-bold transition-all";
                searchContainer.classList.remove('hidden');
                document.getElementById('customerSearchInput').value = '';
                selectCustomer(0, "Select Customer for Delivery...", "");
            }
        }

        function searchCustomers(query) {
            const results = document.getElementById('customerResults');
            const items = results.querySelectorAll('.customer-item');
            
            if (query.length < 1) {
                results.classList.add('hidden');
                return;
            }

            let hasResults = false;
            query = query.toLowerCase();

            items.forEach(item => {
                const name = item.querySelector('.customer-name').innerText.toLowerCase();
                if (name.includes(query)) {
                    item.style.display = 'block';
                    hasResults = true;
                } else {
                    item.style.display = 'none';
                }
            });

            if (hasResults) {
                results.classList.remove('hidden');
            } else {
                results.classList.add('hidden');
            }
        }

        function selectCustomer(id, name, address) {
            document.getElementById('customerIdInput').value = id;
            document.getElementById('displayCustomerName').innerText = name;
            
            const details = document.getElementById('customerDetails');
            const addressEl = document.getElementById('displayCustomerAddress');
            
            if (id !== 0) {
                document.getElementById('customerSearchInput').value = name;
                addressEl.innerText = address || "No Address Provided";
                details.classList.remove('hidden');
            } else {
                details.classList.add('hidden');
            }
            
            document.getElementById('customerResults').classList.add('hidden');
            validateOrder();
        }

        function handleProcessSale(e) {
            if (currentOrderType === 'Delivery') {
                e.preventDefault();
                openRiderModal();
            }
        }

        function openRiderModal() {
            document.getElementById('riderModal').classList.remove('hidden');
        }

        function selectRider(id, el) {
            document.getElementById('riderIdInput').value = id;
            document.querySelectorAll('#riderList > div').forEach(div => div.classList.remove('border-primary', 'bg-primary-container/20'));
            el.classList.add('border-primary', 'bg-primary-container/20');
            document.getElementById('confirmRiderBtn').disabled = false;
        }

        function confirmRiderSelection() {
            document.getElementById('posForm').submit();
        }

        function closeRiderModal() {
            document.getElementById('riderModal').classList.add('hidden');
        }

        function filterProducts(query) {
            const products = document.querySelectorAll('.product-card');
            query = query.toLowerCase();
            products.forEach(p => {
                const name = p.getAttribute('data-name');
                p.style.display = name.includes(query) ? 'flex' : 'none';
            });
        }

        function addToCart(id, name, price, stock) {
            if (cart[id]) {
                if (cart[id].qty < stock) cart[id].qty++;
            } else {
                cart[id] = { id, name, price, qty: 1 };
            }
            renderCart();
        }

        function updateQty(id, delta) {
            if (!cart[id]) return;
            cart[id].qty += delta;
            if (cart[id].qty <= 0) delete cart[id];
            renderCart();
        }

        function removeItem(id) {
            delete cart[id];
            renderCart();
        }

        function renderCart() {
            const container = document.getElementById('cartItems');
            const subtotalEl = document.getElementById('displaySubtotal');
            const totalEl = document.getElementById('cartTotal');
            const totalInput = document.getElementById('totalAmountInput');
            const jsonInput = document.getElementById('cartJsonInput');

            if (Object.keys(cart).length === 0) {
                container.innerHTML = `
                    <div class="h-full flex items-center justify-center text-outline opacity-40 flex-col gap-4">
                        <span class="material-symbols-outlined text-6xl">shopping_cart</span>
                        <p class="font-body-base">Empty Cart</p>
                    </div>`;
                subtotalEl.innerText = "₱0.00";
                totalEl.innerText = "₱0.00";
                totalInput.value = "0";
                validateOrder();
                return;
            }

            container.innerHTML = '';
            let total = 0;
            const itemsList = [];

            for (const id in cart) {
                const item = cart[id];
                const subtotal = item.price * item.qty;
                total += subtotal;
                itemsList.push({ ProductId: item.id, Quantity: item.qty });

                container.innerHTML += `
                    <div class="flex items-center justify-between border-b border-outline-variant py-4 px-2 hover:bg-surface-container-low transition-colors group">
                        <div class="flex-1 pr-4">
                            <h4 class="font-label-bold text-label-bold text-on-surface">${item.name}</h4>
                            <p class="font-body-sm text-body-sm text-on-surface-variant">₱${item.price.toFixed(2)} / ea</p>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="flex items-center win-border rounded bg-surface">
                                <button type="button" onclick="updateQty(${id}, -1)" class="w-8 h-8 flex items-center justify-center hover:bg-surface-variant text-outline border-r border-outline-variant transition-colors"><span class="material-symbols-outlined text-[18px]">remove</span></button>
                                <span class="w-10 text-center font-code-data text-code-data font-bold">${item.qty}</span>
                                <button type="button" onclick="updateQty(${id}, 1)" class="w-8 h-8 flex items-center justify-center hover:bg-surface-variant text-outline border-l border-outline-variant transition-colors"><span class="material-symbols-outlined text-[18px]">add</span></button>
                            </div>
                            <div class="w-20 text-right">
                                <span class="font-code-data text-code-data font-bold text-on-surface">₱${subtotal.toFixed(2)}</span>
                            </div>
                            <button type="button" onclick="removeItem(${id})" class="text-error hover:bg-error-container p-2 rounded transition-colors opacity-0 group-hover:opacity-100"><span class="material-symbols-outlined text-[20px]">delete</span></button>
                        </div>
                    </div>
                `;
            }

            subtotalEl.innerText = `₱${total.toFixed(2)}`;
            totalEl.innerText = `₱${total.toFixed(2)}`;
            totalInput.value = total;
            jsonInput.value = JSON.stringify(itemsList);
            validateOrder();
        }

        function validateOrder() {
            const customerId = document.getElementById('customerIdInput').value;
            const total = parseFloat(document.getElementById('totalAmountInput').value);
            const submitBtn = document.getElementById('submitBtn');
            
            let isValid = total > 0;
            if (currentOrderType === 'Delivery' && customerId === "0") {
                isValid = false;
            }
            
            submitBtn.disabled = !isValid;
        }
    </script>
}
