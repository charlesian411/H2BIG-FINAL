@model System.Data.DataTable
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Page Header -->
<div class="bg-surface px-container-padding py-stack-md border-b border-outline-variant flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 shrink-0 shadow-sm z-0 relative mb-stack-md">
    <div>
        <h2 class="font-display-lg text-display-lg text-on-surface mb-1">@ViewData["Title"]</h2>
        <p class="font-body-sm text-body-sm text-on-surface-variant">Full chronological log of all @(ViewData["Title"]?.ToString().Contains("Delivery") == true ? "deliveries" : "walk-in sales").</p>
    </div>
    <div class="flex flex-row items-center gap-2">
        <a asp-controller="Admin" asp-action="Dashboard" class="h-10 border border-outline-variant hover:bg-surface-container text-on-surface font-label-bold text-label-bold px-6 rounded flex items-center justify-center gap-2 transition-all duration-100 ease-in-out shadow-sm active:scale-95 whitespace-nowrap">
            <span class="material-symbols-outlined">arrow_back</span>
            Back to Dashboard
        </a>
    </div>
</div>

<div class="bg-surface-container-lowest border border-outline-variant rounded flex flex-col overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse font-code-data text-code-data whitespace-nowrap">
            <thead class="bg-surface-container-low border-b border-outline-variant sticky top-0 z-10">
                <tr>
                    <th class="py-stack-sm px-stack-md font-label-bold text-on-surface-variant w-20">ID</th>
                    <th class="py-stack-sm px-stack-md font-label-bold text-on-surface-variant">Timestamp</th>
                    <th class="py-stack-sm px-stack-md font-label-bold text-on-surface-variant">Customer</th>
                    <th class="py-stack-sm px-stack-md font-label-bold text-on-surface-variant">Amount</th>
                    <th class="py-stack-sm px-stack-md font-label-bold text-on-surface-variant">Type</th>
                    <th class="py-stack-sm px-stack-md font-label-bold text-on-surface-variant text-center">Receipts</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Rows.Count > 0)
                {
                    foreach (System.Data.DataRow row in Model.Rows)
                    {
                        <tr class="border-b border-outline-variant hover:bg-surface-container-low transition-colors group">
                            <td class="py-stack-sm px-stack-md text-primary font-bold">#@row["id"]</td>
                            <td class="py-stack-sm px-stack-md text-on-surface-variant">@Convert.ToDateTime(row["date_time"]).ToString("yyyy-MM-dd HH:mm:ss")</td>
                            <td class="py-stack-sm px-stack-md text-on-surface">@row["CustomerName"]</td>
                            <td class="py-stack-sm px-stack-md font-bold text-on-surface">₱@Convert.ToDecimal(row["total_amount"]).ToString("0.00")</td>
                            <td class="py-stack-sm px-stack-md">
                                <span class="px-2 py-0.5 rounded text-[10px] font-bold @(row["type"].ToString() == "Walk-In" ? "bg-success/10 text-success" : "bg-primary/10 text-primary")">@row["type"]</span>
                            </td>
                            <td class="py-stack-sm px-stack-md text-center">
                                <a asp-controller="Sales" asp-action="Receipt" asp-route-id="@row["id"]" target="_blank" class="inline-flex items-center gap-1 px-3 py-1 bg-surface-container-high hover:bg-primary hover:text-on-primary rounded text-[11px] font-label-bold transition-all shadow-sm border border-outline-variant/30">
                                    <span class="material-symbols-outlined text-[16px]">receipt_long</span>
                                    View Printed Receipts
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="py-20 text-center text-on-surface-variant font-body-sm italic">
                            No transaction history found for this category.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
