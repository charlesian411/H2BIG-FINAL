@{
    ViewData["Title"] = "Rider Remittance";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var expectedBottles = Convert.ToInt32(ViewBag.ExpectedBottles);
    var expectedEmpties = Convert.ToInt32(ViewBag.ExpectedEmpties);
    var expectedCash = Convert.ToDecimal(ViewBag.ExpectedCash);
}

<div class="flex flex-col h-full">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-outline-variant pb-4 mb-stack-md">
        <div>
            <h1 class="font-headline-lg text-headline-lg font-bold text-primary mb-1">Rider Remittance</h1>
            <p class="font-body-sm text-body-sm text-on-surface-variant flex gap-4">
                <span>Date: <span class="font-bold text-on-surface">@ViewBag.Date</span></span>
                <span>Rider: <span class="font-bold text-on-surface">@ViewBag.RiderName</span></span>
            </p>
        </div>
        <div class="bg-surface-container border border-outline-variant rounded-full px-4 py-2 flex items-center gap-2 shadow-sm">
            <span class="material-symbols-outlined text-[18px] text-outline">schedule</span>
            <span class="font-label-bold text-label-bold text-on-surface-variant uppercase tracking-wide text-[11px]">Status: Pending Check-In</span>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="bg-primary-container text-on-primary-container p-4 rounded-lg mb-6 border border-primary shadow-sm font-label-bold flex items-center gap-2">
            <span class="material-symbols-outlined text-[20px]">check_circle</span>
            @TempData["Success"]
        </div>
    }

    <form asp-action="SubmitRemittance" method="post" id="remittanceForm" class="grid grid-cols-1 lg:grid-cols-12 gap-stack-lg items-start">
        <!-- Hidden Expected Values -->
        <input type="hidden" name="deliveryId" value="@ViewBag.DeliveryId" />
        <input type="hidden" name="expectedBottles" id="sysBottles" value="@expectedBottles" />
        <input type="hidden" name="expectedEmpties" id="sysEmpties" value="@expectedEmpties" />
        <input type="hidden" name="expectedCash" id="sysCash" value="@expectedCash" />

        <!-- Left Column: Declaration -->
        <div class="lg:col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm overflow-hidden flex flex-col">
            <div class="bg-surface-container-low p-4 border-b border-outline-variant flex items-center gap-2">
                <span class="material-symbols-outlined text-[20px] text-primary">edit_document</span>
                <h2 class="font-label-bold text-label-bold text-on-surface uppercase tracking-wide">Rider Declaration</h2>
            </div>
            
            <div class="p-6 space-y-6">
                <!-- Bottles Delivered -->
                <div class="space-y-2">
                    <label class="block font-label-bold text-label-bold text-on-surface-variant">Bottles Delivered (5 Gal)</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline text-[18px]">water_bottle</span>
                        <input type="number" name="declaredBottles" id="decBottles" class="w-full pl-10 pr-4 py-3 border border-outline-variant rounded-lg font-code-data text-right text-on-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="0" oninput="calculateVariance()" required />
                    </div>
                </div>

                <!-- Empties Collected -->
                <div class="space-y-2">
                    <label class="block font-label-bold text-label-bold text-on-surface-variant">Empties Collected</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline text-[18px]">recycling</span>
                        <input type="number" name="declaredEmpties" id="decEmpties" class="w-full pl-10 pr-4 py-3 border border-outline-variant rounded-lg font-code-data text-right text-on-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="0" oninput="calculateVariance()" required />
                    </div>
                </div>

                <!-- Cash Collected -->
                <div class="space-y-2">
                    <label class="block font-label-bold text-label-bold text-on-surface-variant">Cash Collected (₱)</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 material-symbols-outlined text-outline text-[18px]">payments</span>
                        <input type="number" step="0.01" name="declaredCash" id="decCash" class="w-full pl-10 pr-4 py-3 border border-outline-variant rounded-lg font-code-data text-right text-on-surface focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all" placeholder="0.00" oninput="calculateVariance()" required />
                    </div>
                </div>
            </div>
        </div>

        <!-- Right Column: Variance Analysis -->
        <div class="lg:col-span-8 flex flex-col gap-stack-md">
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm overflow-hidden flex flex-col">
                <div class="bg-surface-container-low p-4 border-b border-outline-variant flex items-center justify-between">
                    <div class="flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px] text-primary">analytics</span>
                        <h2 class="font-label-bold text-label-bold text-on-surface uppercase tracking-wide">Trip Variance Analysis</h2>
                    </div>
                </div>
                
                <div class="overflow-x-auto">
                    <table class="w-full text-center border-collapse">
                        <thead class="bg-surface-container-lowest border-b border-outline-variant">
                            <tr>
                                <th class="py-4 px-4 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 w-1/4">Metric</th>
                                <th class="py-4 px-4 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 w-1/4">System Expected</th>
                                <th class="py-4 px-4 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 w-1/4">Rider Declared</th>
                                <th class="py-4 px-4 font-label-bold text-label-bold text-outline border-r border-outline-variant/50 w-1/6">Variance</th>
                                <th class="py-4 px-4 font-label-bold text-label-bold text-outline w-1/12">Status</th>
                            </tr>
                        </thead>
                        <tbody class="font-code-data text-code-data text-on-surface">
                            <!-- Bottles -->
                            <tr class="border-b border-outline-variant hover:bg-surface-container-low transition-colors">
                                <td class="py-4 px-4 border-r border-outline-variant/50 text-left font-body-sm text-on-surface-variant">Bottles Delivered</td>
                                <td class="py-4 px-4 border-r border-outline-variant/50 font-bold">@expectedBottles</td>
                                <td class="py-4 px-4 border-r border-outline-variant/50 font-bold text-primary" id="valDecBottles">--</td>
                                <td class="py-4 px-4 border-r border-outline-variant/50 font-bold" id="varBottles">--</td>
                                <td class="py-4 px-4 flex justify-center items-center">
                                    <div id="statBottles" class="w-3 h-3 rounded-full bg-outline-variant"></div>
                                </td>
                            </tr>
                            
                            <!-- Empties -->
                            <tr class="border-b border-outline-variant hover:bg-surface-container-low transition-colors">
                                <td class="py-4 px-4 border-r border-outline-variant/50 text-left font-body-sm text-on-surface-variant">Empties Returned</td>
                                <td class="py-4 px-4 border-r border-outline-variant/50 font-bold">@expectedEmpties</td>
                                <td class="py-4 px-4 border-r border-outline-variant/50 font-bold text-primary" id="valDecEmpties">--</td>
                                <td class="py-4 px-4 border-r border-outline-variant/50 font-bold" id="varEmpties">--</td>
                                <td class="py-4 px-4 flex justify-center items-center">
                                    <div id="statEmpties" class="w-3 h-3 rounded-full bg-outline-variant"></div>
                                </td>
                            </tr>

                            <!-- Cash -->
                            <tr class="border-b border-outline-variant hover:bg-surface-container-low transition-colors">
                                <td class="py-4 px-4 border-r border-outline-variant/50 text-left font-body-sm text-on-surface-variant">Cash Remittance</td>
                                <td class="py-4 px-4 border-r border-outline-variant/50 font-bold">₱@expectedCash.ToString("0.00")</td>
                                <td class="py-4 px-4 border-r border-outline-variant/50 font-bold text-primary" id="valDecCash">--</td>
                                <td class="py-4 px-4 border-r border-outline-variant/50 font-bold" id="varCash">--</td>
                                <td class="py-4 px-4 flex justify-center items-center">
                                    <div id="statCash" class="w-3 h-3 rounded-full bg-outline-variant"></div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Warning Banner -->
                <div id="warningBanner" class="hidden bg-[#FCE8E6] border-t border-[#C5221F]/30 p-4 flex gap-3 items-start animate-in fade-in slide-in-from-top-2 duration-300">
                    <span class="material-symbols-outlined text-[#C5221F] text-[20px] mt-0.5">warning</span>
                    <div>
                        <h4 class="font-label-bold text-label-bold text-[#C5221F] mb-1">Discrepancy Warning</h4>
                        <p class="font-body-sm text-body-sm text-[#C5221F]/80">Calculation based on current input shows a variance. Staff verification requires manual override code if submitted with unresolved shortages.</p>
                    </div>
                </div>
            </div>

            <!-- Submit Button Area -->
            <div class="bg-surface-container p-4 rounded-xl border border-outline-variant flex justify-end">
                <button type="submit" id="btnSubmit" class="bg-primary hover:bg-primary-container text-on-primary font-label-bold py-3 px-8 rounded-lg shadow-sm transition-all flex items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">send</span>
                    Submit Remittance
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        function calculateVariance() {
            // Get inputs
            const decBottles = document.getElementById('decBottles').value;
            const decEmpties = document.getElementById('decEmpties').value;
            const decCash = document.getElementById('decCash').value;

            // Get expected
            const sysBottles = parseInt(document.getElementById('sysBottles').value) || 0;
            const sysEmpties = parseInt(document.getElementById('sysEmpties').value) || 0;
            const sysCash = parseFloat(document.getElementById('sysCash').value) || 0.0;

            let hasDiscrepancy = false;

            // Update Bottles
            if (decBottles !== '') {
                const val = parseInt(decBottles);
                const variance = val - sysBottles;
                document.getElementById('valDecBottles').innerText = val;
                document.getElementById('varBottles').innerText = variance > 0 ? '+' + variance : variance;
                updateStatus('statBottles', 'varBottles', variance);
                if (variance < 0) hasDiscrepancy = true;
            }

            // Update Empties
            if (decEmpties !== '') {
                const val = parseInt(decEmpties);
                const variance = val - sysEmpties;
                document.getElementById('valDecEmpties').innerText = val;
                document.getElementById('varEmpties').innerText = variance > 0 ? '+' + variance : variance;
                updateStatus('statEmpties', 'varEmpties', variance);
                if (variance < 0) hasDiscrepancy = true;
            }

            // Update Cash
            if (decCash !== '') {
                const val = parseFloat(decCash);
                const variance = val - sysCash;
                document.getElementById('valDecCash').innerText = '₱' + val.toFixed(2);
                document.getElementById('varCash').innerText = (variance > 0 ? '+₱' : (variance < 0 ? '-₱' : '₱')) + Math.abs(variance).toFixed(2);
                updateStatus('statCash', 'varCash', variance);
                if (variance < 0) hasDiscrepancy = true;
            }

            // Toggle Warning
            const warning = document.getElementById('warningBanner');
            if (hasDiscrepancy) {
                warning.classList.remove('hidden');
            } else {
                warning.classList.add('hidden');
            }
        }

        function updateStatus(dotId, varId, variance) {
            const dot = document.getElementById(dotId);
            const varText = document.getElementById(varId);
            
            dot.className = 'w-3 h-3 rounded-full'; // reset
            varText.className = 'py-4 px-4 border-r border-outline-variant/50 font-bold'; // reset

            if (variance === 0) {
                dot.classList.add('bg-[#137333]'); // Green
                varText.classList.add('text-[#137333]');
            } else if (variance < 0) {
                dot.classList.add('bg-[#C5221F]'); // Red
                varText.classList.add('text-[#C5221F]');
            } else {
                dot.classList.add('bg-[#F57F17]'); // Yellow for over
                varText.classList.add('text-[#F57F17]');
            }
        }
    </script>
}
